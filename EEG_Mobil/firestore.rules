rules_version = '2';
// İçerik (video/metin) Firestore'da tutulmaz — uygulamaya gömülüdür.
// Burada yalnızca denek / deney / sonuç / davranışsal yanıtlar saklanır.
// Üretimde App Check veya ağ kısıtı önerilir.
service cloud.firestore {
  match /databases/{database}/documents {
    match /participants/{id} {
      allow read, write: if true;
    }
    match /experiments/{id} {
      allow read, write: if true;
    }
    match /results/{id} {
      allow read, write: if true;
    }
    match /video_watch_events/{id} {
      allow read, write: if true;
    }
    match /text_quiz_responses/{id} {
      allow read, write: if true;
    }
  }
}
