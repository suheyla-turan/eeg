rules_version = '2';
// Araştırma uygulaması — Auth yok / anonim Auth.
// Yayınlamak için: firebase deploy --only storage
// veya Console > Storage > Rules
service firebase.storage {
  match /b/{bucket}/o {
    match /videos/{allPaths=**} {
      allow read, write: if true;
    }
    match /texts/{allPaths=**} {
      allow read, write: if true;
    }
    match /eeg/{allPaths=**} {
      allow read, write: if true;
    }
    match /reports/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
